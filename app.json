{
  "expo": {
    "name": "Stellar Field",
    "slug": "stellar-field",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "stellarfield",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0E17"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stellar.field",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Stellar Field uses the microphone for offline voice observation logging at the eyepiece. Audio is transcribed locally and never leaves your device."
      }
    },
    "android": {
      "package": "com.stellar.field",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0E17"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Stellar Field uses the microphone for offline voice observation logging at the eyepiece."
        }
      ],
      "expo-web-browser",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": { "minSdkVersion": 29 }
        }
      ],
      "@qvac/sdk/expo-plugin"
    ],
    "extra": {
      "eas": {
        "projectId": "1a6645de-53d8-4636-96cb-1df28fab67cf"
      }
    }
  }
}
